{
  "name": "club-sandwich-streaming",
  "productName": "Club Sandwich Streaming",
  "version": "1.0.4",
  "description": "Club Sandwich Streaming — a movie & TV streaming desktop app (TMDB + VidLink).",
  "main": "electron/main.js",
  "author": "Club Sandwich",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/make-icons.js",
    "dist": "electron-builder",
    "dist:portable": "electron-builder --win portable",
    "release": "electron-builder --publish always",
    "build:web": "node scripts/build-web.js",
    "android:sync": "npm run build:web && cap sync android",
    "android:apk": "npm run android:sync && cd android && gradlew.bat assembleDebug"
  },
  "build": {
    "appId": "dev.clubsandwich.streaming",
    "productName": "Club Sandwich Streaming",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "manifest.webmanifest",
      "sw.js",
      "assets/**/*",
      "electron/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.entertainment",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Club Sandwich Streaming"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Official-Nugget",
        "repo": "VideoPlayer",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@xhayper/discord-rpc": "^1.3.4",
    "electron-updater": "^6.8.9"
  }
}
